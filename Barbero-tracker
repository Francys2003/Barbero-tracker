<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0e0800">
<meta name="description" content="Cronista digitale degli spettacoli del Professor Alessandro Barbero">

<!-- PWA / Home screen icon -->
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%230e0800'/%3E%3Ctext x='50%25' y='54%25' dominant-baseline='middle' text-anchor='middle' font-size='40'%3E📖%3C/text%3E%3C/svg%3E">
<link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'%3E%3Crect width='180' height='180' rx='36' fill='%230e0800'/%3E%3Ctext x='50%25' y='54%25' dominant-baseline='middle' text-anchor='middle' font-size='110'%3E📖%3C/text%3E%3C/svg%3E">

<!-- Web App Manifest inline via JS (GitHub Pages non ha server-side) -->
<script>
const manifest = {
  name: "Barbero Tracker",
  short_name: "Barbero",
  description: "Cronista digitale degli spettacoli del Professore",
  start_url: "./",
  display: "standalone",
  background_color: "#0e0800",
  theme_color: "#0e0800",
  icons: [
    { src: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'%3E%3Crect width='192' height='192' rx='38' fill='%230e0800'/%3E%3Ctext x='50%25' y='54%25' dominant-baseline='middle' text-anchor='middle' font-size='120'%3E%F0%9F%93%96%3C/text%3E%3C/svg%3E", sizes: "192x192", type: "image/svg+xml" },
    { src: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='100' fill='%230e0800'/%3E%3Ctext x='50%25' y='54%25' dominant-baseline='middle' text-anchor='middle' font-size='320'%3E%F0%9F%93%96%3C/text%3E%3C/svg%3E", sizes: "512x512", type: "image/svg+xml" }
  ]
};
const blob = new Blob([JSON.stringify(manifest)], {type:'application/manifest+json'});
const murl = URL.createObjectURL(blob);
const ml = document.createElement('link');
ml.rel = 'manifest'; ml.href = murl;
document.currentScript.after(ml);
</script>

<title>Barbero Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
<style>
:root {
  --parchment: #f5ead0;
  --ink: #1a0e00;
  --gold: #c9922a;
  --gold-light: #e8b84b;
  --green: #4caf50;
  --red: #e74c3c;
  --radius: 6px;
  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
html { font-size:16px; }
body {
  background:#0e0800;
  font-family:'Cormorant Garamond',Georgia,serif;
  color:var(--parchment);
  min-height:100vh;
  overflow-x:hidden;
}
.page {
  max-width:700px;
  margin:0 auto;
  padding:calc(16px + var(--safe-top)) 16px calc(80px + var(--safe-bottom));
  background:linear-gradient(180deg,#1a0e00 0%,#0e0800 100%);
  min-height:100vh;
}

/* HEADER */
.header { text-align:center; padding:20px 0 24px; }
.header-deco { color:var(--gold); font-size:1rem; letter-spacing:0.4em; opacity:0.5; display:block; margin-bottom:8px; }
h1 { font-family:'Cinzel',serif; font-size:clamp(1.6rem,7vw,2.8rem); font-weight:600; color:var(--gold-light); text-shadow:0 0 40px rgba(201,146,42,0.4); line-height:1.1; }
h1 small { display:block; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:0.45em; font-weight:400; color:rgba(245,234,208,0.6); letter-spacing:0.15em; margin-top:5px; }
.divider { display:flex; align-items:center; gap:10px; margin:14px 0 0; opacity:0.3; }
.divider::before,.divider::after { content:''; flex:1; height:1px; background:linear-gradient(90deg,transparent,var(--gold),transparent); }
.divider span { color:var(--gold); font-size:0.8rem; }

/* STATUS */
.status-bar { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; gap:8px; flex-wrap:wrap; }
.badge { display:inline-flex; align-items:center; gap:7px; background:rgba(201,146,42,0.1); border:1px solid rgba(201,146,42,0.25); border-radius:20px; padding:7px 14px; font-family:'Cinzel',serif; font-size:0.65rem; letter-spacing:0.1em; color:var(--gold-light); }
.dot { width:7px; height:7px; border-radius:50%; background:#4caf50; box-shadow:0 0 5px #4caf50; animation:blink 2s infinite; flex-shrink:0; }
.dot.red { background:var(--red); box-shadow:0 0 5px var(--red); }
.dot.orange { background:#ff9800; box-shadow:0 0 5px #ff9800; }
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
.last-upd { font-style:italic; font-size:0.78rem; color:rgba(245,234,208,0.35); }

/* SEARCH */
.search-row { display:flex; gap:8px; margin-bottom:14px; align-items:stretch; }
.search-box { flex:1; position:relative; }
.search-box input {
  width:100%;
  background:rgba(245,234,208,0.07);
  border:1.5px solid rgba(201,146,42,0.2);
  border-radius:var(--radius);
  padding:13px 40px 13px 40px;
  color:var(--parchment);
  font-family:'Cormorant Garamond',serif;
  font-size:16px;
  outline:none;
  -webkit-appearance:none;
  transition:border-color 0.2s;
}
.search-box input:focus { border-color:rgba(201,146,42,0.6); background:rgba(245,234,208,0.1); }
.search-box input::placeholder { color:rgba(245,234,208,0.3); font-style:italic; }
.search-icon { position:absolute; left:13px; top:50%; transform:translateY(-50%); color:rgba(201,146,42,0.5); font-size:1rem; pointer-events:none; }
.btn-clear { position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; color:rgba(245,234,208,0.4); font-size:1.1rem; cursor:pointer; padding:6px; display:none; min-width:32px; min-height:32px; }
.btn-clear.visible { display:flex; align-items:center; justify-content:center; }
.btn-search { background:linear-gradient(135deg,var(--gold) 0%,#a07020 100%); border:none; border-radius:var(--radius); padding:13px 18px; font-family:'Cinzel',serif; font-size:0.7rem; letter-spacing:0.1em; color:var(--ink); font-weight:600; cursor:pointer; white-space:nowrap; transition:all 0.2s; -webkit-appearance:none; min-height:48px; min-width:80px; }
.btn-search:active { filter:brightness(0.9); transform:scale(0.97); }
.btn-search:disabled { opacity:0.6; }

/* CHIPS */
.filters { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:16px; }
.chip { font-family:'Cinzel',serif; font-size:0.6rem; letter-spacing:0.1em; padding:8px 14px; border-radius:20px; border:1px solid rgba(201,146,42,0.2); background:transparent; color:rgba(245,234,208,0.5); cursor:pointer; -webkit-appearance:none; min-height:36px; transition:all 0.15s; }
.chip:active { transform:scale(0.95); }
.chip.on { border-color:var(--gold); background:rgba(201,146,42,0.15); color:var(--gold-light); }

/* NOTIFICHE */
.notif-row { display:flex; align-items:center; background:rgba(245,234,208,0.04); border:1px solid rgba(245,234,208,0.08); border-radius:var(--radius); padding:12px 14px; margin-bottom:16px; gap:12px; }
.notif-ico { font-size:1.2rem; flex-shrink:0; }
.notif-txt { flex:1; font-style:italic; font-size:0.85rem; color:rgba(245,234,208,0.55); line-height:1.4; }
.notif-txt strong { display:block; font-style:normal; font-family:'Cinzel',serif; font-size:0.65rem; letter-spacing:0.08em; color:rgba(245,234,208,0.75); margin-bottom:2px; }
.toggle-wrap { flex-shrink:0; }
.toggle { position:relative; width:46px; height:26px; cursor:pointer; display:block; }
.toggle input { opacity:0; width:0; height:0; position:absolute; }
.toggle-track { position:absolute; inset:0; background:rgba(245,234,208,0.12); border-radius:13px; transition:background 0.2s; border:1px solid rgba(245,234,208,0.15); }
.toggle input:checked + .toggle-track { background:var(--green); border-color:var(--green); }
.toggle-thumb { position:absolute; top:3px; left:3px; width:18px; height:18px; background:white; border-radius:50%; transition:transform 0.2s; box-shadow:0 1px 4px rgba(0,0,0,0.4); pointer-events:none; }
.toggle input:checked ~ .toggle-thumb { transform:translateX(20px); }

/* FONTI */
.sec-title { font-family:'Cinzel',serif; font-size:0.62rem; letter-spacing:0.18em; color:rgba(201,146,42,0.5); margin-bottom:8px; }
.sources-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:6px; margin-bottom:20px; }
.src { display:flex; align-items:center; gap:7px; background:rgba(245,234,208,0.03); border:1px solid rgba(245,234,208,0.07); border-radius:var(--radius); padding:9px 11px; cursor:pointer; transition:all 0.15s; min-height:44px; -webkit-appearance:none; text-align:left; width:100%; }
.src:active { transform:scale(0.97); }
.src.on { border-color:rgba(201,146,42,0.4); background:rgba(201,146,42,0.08); }
.src-dot { width:6px; height:6px; border-radius:50%; background:rgba(245,234,208,0.15); flex-shrink:0; }
.src.on .src-dot { background:var(--green); box-shadow:0 0 4px var(--green); }
.src-name { font-size:0.78rem; color:rgba(245,234,208,0.45); line-height:1.2; }
.src.on .src-name { color:rgba(245,234,208,0.85); }

/* AI BOX */
.ai-box { background:rgba(201,146,42,0.05); border:1px solid rgba(201,146,42,0.18); border-radius:var(--radius); padding:14px 16px; margin-bottom:16px; font-style:italic; font-size:0.88rem; color:rgba(245,234,208,0.6); line-height:1.6; display:none; }
.ai-box.show { display:block; }
.ai-box::before { content:'✦ '; color:var(--gold); font-style:normal; }

/* SPINNER */
.spinner-wrap { text-align:center; padding:40px 0; display:none; }
.spinner-wrap.show { display:block; }
.spinner { width:36px; height:36px; border:2px solid rgba(201,146,42,0.15); border-top-color:var(--gold); border-radius:50%; animation:spin 0.75s linear infinite; margin:0 auto 12px; }
@keyframes spin { to { transform:rotate(360deg); } }
.spinner-wrap p { font-style:italic; font-size:0.85rem; color:rgba(245,234,208,0.35); }

/* EVENTS */
.events-hd { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
.events-count { font-style:italic; font-size:0.78rem; color:rgba(245,234,208,0.3); }
.empty { text-align:center; padding:50px 20px; color:rgba(245,234,208,0.2); }
.empty-ico { font-size:2.5rem; display:block; margin-bottom:10px; }
.empty p { font-style:italic; font-size:0.9rem; }

/* CARD */
.card { background:rgba(245,234,208,0.04); border:1px solid rgba(245,234,208,0.08); border-left:3px solid var(--gold); border-radius:var(--radius); padding:14px; margin-bottom:8px; animation:fadeUp 0.35s ease both; }
@keyframes fadeUp { from{opacity:0;transform:translateY(8px);} to{opacity:1;transform:none;} }
.card:active { transform:scale(0.99); }
.card.past { opacity:0.4; border-left-color:rgba(245,234,208,0.12); }
.card.nuovo { border-left-color:var(--red); }
.card-top { display:flex; gap:12px; align-items:flex-start; margin-bottom:8px; }
.date-block { background:rgba(201,146,42,0.1); border:1px solid rgba(201,146,42,0.2); border-radius:4px; padding:6px 10px; text-align:center; min-width:52px; flex-shrink:0; }
.date-day { font-family:'Cinzel',serif; font-size:1.25rem; font-weight:600; color:var(--gold-light); line-height:1; }
.date-mon { font-family:'Cinzel',serif; font-size:0.55rem; letter-spacing:0.1em; color:rgba(201,146,42,0.65); margin-top:2px; }
.date-yr  { font-size:0.65rem; color:rgba(201,146,42,0.4); font-style:italic; }
.card-body { flex:1; min-width:0; }
.card-title { font-size:1rem; font-weight:600; color:var(--parchment); line-height:1.3; margin-bottom:5px; }
.card-meta { display:flex; flex-wrap:wrap; gap:8px; font-style:italic; font-size:0.8rem; color:rgba(245,234,208,0.45); margin-bottom:5px; }
.card-desc { font-style:italic; font-size:0.8rem; color:rgba(245,234,208,0.4); line-height:1.5; margin-bottom:7px; }
.card-tags { display:flex; flex-wrap:wrap; gap:5px; }
.tag { font-family:'Cinzel',serif; font-size:0.55rem; letter-spacing:0.08em; padding:3px 8px; border-radius:3px; }
.tag-new  { background:rgba(231,76,60,0.15);  border:1px solid rgba(231,76,60,0.35);  color:#ef9a9a; }
.tag-free { background:rgba(76,175,80,0.12);  border:1px solid rgba(76,175,80,0.3);   color:#a5d6a7; }
.tag-paid { background:rgba(201,146,42,0.1);  border:1px solid rgba(201,146,42,0.3);  color:var(--gold-light); }
.tag-web  { background:rgba(33,150,243,0.1);  border:1px solid rgba(33,150,243,0.3);  color:#90caf9; }
.tag-past { background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1); color:rgba(245,234,208,0.25); }
.src-badge { font-family:'Cinzel',serif; font-size:0.55rem; letter-spacing:0.08em; padding:3px 8px; border-radius:3px; background:rgba(245,234,208,0.04); border:1px solid rgba(245,234,208,0.1); color:rgba(245,234,208,0.3); white-space:nowrap; align-self:flex-start; margin-left:auto; }

/* TOAST */
.toast { position:fixed; bottom:calc(24px + var(--safe-bottom)); left:50%; transform:translateX(-50%) translateY(80px); background:#1a2d12; border:1px solid rgba(76,175,80,0.5); border-radius:20px; padding:10px 20px; font-style:italic; font-size:0.85rem; color:#a5d6a7; white-space:nowrap; opacity:0; transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1); z-index:999; max-width:calc(100vw - 40px); text-align:center; }
.toast.show { transform:translateX(-50%) translateY(0); opacity:1; }

/* ALERT BASE */
.overlay { position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:200; display:flex; opacity:0; pointer-events:none; transition:opacity 0.25s; }
.overlay.show { opacity:1; pointer-events:all; }

/* iOS ALERT */
.ios-alert { align-items:flex-end; padding:16px; padding-bottom:calc(16px + var(--safe-bottom)); }
.ios-card { background:#1a1200; border:1px solid rgba(201,146,42,0.3); border-radius:16px; padding:24px 20px; width:100%; max-width:500px; margin:0 auto; transform:translateY(40px); transition:transform 0.3s; }
.ios-alert.show .ios-card { transform:translateY(0); }
.ios-card h3 { font-family:'Cinzel',serif; font-size:0.9rem; letter-spacing:0.1em; color:var(--gold-light); margin-bottom:10px; }
.ios-card p { font-style:italic; font-size:0.88rem; color:rgba(245,234,208,0.6); line-height:1.6; margin-bottom:14px; }
.ios-card ol { font-size:0.85rem; color:rgba(245,234,208,0.65); padding-left:18px; margin-bottom:18px; line-height:2; }
.ios-card ol li strong { color:var(--gold-light); font-style:normal; }
.ios-btn { width:100%; background:linear-gradient(135deg,var(--gold),#8a6018); border:none; border-radius:8px; padding:13px; font-family:'Cinzel',serif; font-size:0.75rem; letter-spacing:0.1em; color:var(--ink); font-weight:600; cursor:pointer; -webkit-appearance:none; }

/* ANDROID ALERT */
.android-alert { align-items:center; justify-content:center; padding:20px; }
.android-card { background:#1a1200; border:1px solid rgba(201,146,42,0.3); border-radius:12px; padding:22px 18px; width:100%; max-width:400px; }
.android-card h3 { font-family:'Cinzel',serif; font-size:0.85rem; letter-spacing:0.1em; color:var(--gold-light); margin-bottom:10px; }
.android-card p { font-style:italic; font-size:0.85rem; color:rgba(245,234,208,0.6); line-height:1.6; margin-bottom:14px; }
.android-btns { display:flex; gap:8px; }
.android-btn { flex:1; background:rgba(201,146,42,0.15); border:1px solid rgba(201,146,42,0.35); border-radius:8px; padding:11px; font-family:'Cinzel',serif; font-size:0.65rem; letter-spacing:0.08em; color:var(--gold-light); cursor:pointer; -webkit-appearance:none; }
.android-btn.primary { background:linear-gradient(135deg,var(--gold),#8a6018); border:none; color:var(--ink); font-weight:600; }

/* API KEY BANNER */
.key-banner { background:rgba(231,76,60,0.08); border:1px solid rgba(231,76,60,0.25); border-radius:var(--radius); padding:12px 14px; margin-bottom:14px; font-style:italic; font-size:0.82rem; color:rgba(231,76,60,0.8); line-height:1.5; display:none; }
.key-banner.show { display:block; }
.key-banner a { color:#ef9a9a; }
</style>
</head>
<body>
<div class="page">

  <header class="header">
    <span class="header-deco">❧ ✦ ❧</span>
    <h1>BARBERO TRACKER<small>Cronista digitale degli spettacoli del Professore</small></h1>
    <div class="divider"><span>⚜</span></div>
  </header>

  <div class="status-bar">
    <div class="badge"><div class="dot" id="dot"></div><span id="statusTxt">PRONTO</span></div>
    <div class="last-upd" id="lastUpd">—</div>
  </div>

  <!-- API KEY BANNER (mostrato solo su GitHub Pages senza key) -->
  <div class="key-banner" id="keyBanner">
    ⚠ Per usare la ricerca AI inserisci la tua <strong>Anthropic API key</strong> nel campo qui sotto.
    Ottienila su <a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a>. La chiave rimane solo nel tuo browser.
    <div style="margin-top:10px; display:flex; gap:8px;">
      <input id="keyInput" type="password" placeholder="sk-ant-…"
        style="flex:1;background:rgba(245,234,208,0.07);border:1px solid rgba(201,146,42,0.3);border-radius:4px;padding:8px 10px;color:var(--parchment);font-size:14px;outline:none;font-family:monospace;">
      <button onclick="saveKey()" style="background:linear-gradient(135deg,var(--gold),#8a6018);border:none;border-radius:4px;padding:8px 14px;font-family:'Cinzel',serif;font-size:0.65rem;letter-spacing:0.08em;color:var(--ink);font-weight:600;cursor:pointer;">Salva</button>
    </div>
  </div>

  <!-- RICERCA -->
  <div class="search-row">
    <div class="search-box">
      <span class="search-icon">🔍</span>
      <input type="search" id="searchInput"
        placeholder="Filtra per città, teatro…"
        autocomplete="off" autocorrect="off"
        autocapitalize="off" spellcheck="false">
      <button class="btn-clear" id="clearBtn" onclick="clearSearch()">✕</button>
    </div>
    <button class="btn-search" id="fetchBtn" onclick="fetchEvents()">✦ Cerca</button>
  </div>

  <!-- FILTRI -->
  <div class="filters" id="filters" style="display:none">
    <button class="chip on" id="cAll"    onclick="setChip('all')">Tutti</button>
    <button class="chip"    id="cFuture" onclick="setChip('future')">Futuri</button>
    <button class="chip"    id="cFree"   onclick="setChip('free')">Gratuiti</button>
  </div>

  <!-- NOTIFICHE -->
  <div class="notif-row">
    <div class="notif-ico">🔔</div>
    <div class="notif-txt">
      <strong>NOTIFICHE SPETTACOLI</strong>
      Avvisami per nuovi eventi del Professore
    </div>
    <div class="toggle-wrap">
      <label class="toggle">
        <input type="checkbox" id="notifCheck" onchange="handleNotif()">
        <div class="toggle-track"></div>
        <div class="toggle-thumb"></div>
      </label>
    </div>
  </div>

  <!-- FONTI -->
  <div class="sec-title">⚔ FONTI MONITORATE</div>
  <div class="sources-grid" id="srcGrid"></div>

  <!-- AI SUMMARY -->
  <div class="ai-box" id="aiBox"></div>

  <!-- SPINNER -->
  <div class="spinner-wrap" id="spinner">
    <div class="spinner"></div>
    <p>Il cronista consulta gli annali…</p>
  </div>

  <!-- EVENTI -->
  <div class="events-hd">
    <div class="sec-title" style="margin:0">⚔ SPETTACOLI & CONFERENZE</div>
    <div class="events-count" id="evtCount"></div>
  </div>
  <div id="evtList">
    <div class="empty">
      <span class="empty-ico">📖</span>
      <p>Premi <em>Cerca</em> per trovare tutti gli eventi</p>
    </div>
  </div>

</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- iOS ALERT -->
<div class="overlay ios-alert" id="iosAlert">
  <div class="ios-card">
    <h3>🍎 NOTIFICHE SU IPHONE</h3>
    <p>Su iPhone Safari le notifiche richiedono di salvare la pagina come app sulla schermata Home:</p>
    <ol>
      <li>Tocca il tasto <strong>Condividi ⬆</strong> in basso</li>
      <li>Scegli <strong>"Aggiungi a Home"</strong></li>
      <li>Apri l'app dalla schermata Home</li>
      <li>Riattiva le notifiche da qui</li>
    </ol>
    <p>Nel frattempo attivo l'<strong>aggiornamento automatico ogni 30 min</strong>.</p>
    <button class="ios-btn" onclick="closeIosAlert()">Ho capito ✦</button>
  </div>
</div>

<!-- ANDROID ALERT -->
<div class="overlay android-alert" id="androidAlert">
  <div class="android-card">
    <h3>🔔 ATTIVARE NOTIFICHE</h3>
    <p>Quando il browser chiede il permesso, tocca <strong>"Consenti"</strong> per ricevere avvisi sui nuovi spettacoli di Barbero.</p>
    <div class="android-btns">
      <button class="android-btn" onclick="closeAndroidAlert()">Annulla</button>
      <button class="android-btn primary" onclick="doRequestNotif()">Continua ✦</button>
    </div>
  </div>
</div>

<script>
// ── DATI ─────────────────────────────────────────────
const SOURCES = [
  {name:'Vassalli di Barbero', on:true},
  {name:'Ticketone',           on:true},
  {name:'Vivaticket',          on:true},
  {name:'Eventbrite',          on:true},
  {name:'Laterza / Lezioni',   on:true},
  {name:'Auditorium Roma',     on:true},
  {name:'BookCity Milano',     on:false},
  {name:'Più Libri Più Liberi',on:false},
  {name:'Festival del Classico',on:false},
  {name:'Chora / Podcast',     on:true},
];

const FALLBACK = [
  {title:"Lezioni di Storia — Auditorium Roma",       day:"15",month:"Mar",year:"2026",city:"Roma",              venue:"Auditorium Parco della Musica",desc:"Nuova stagione delle Lezioni di Storia con Barbero",                price:"da €15",  free:false,online:false,src:"Laterza",            past:false,nuovo:true },
  {title:"Barbero & Cazzullo: San Francesco",         day:"22",month:"Mar",year:"2026",city:"Castenedolo (BS)",  venue:"Castenedolo Incontra",          desc:"Due storici insieme sul palco per San Francesco d'Assisi",     price:"gratuito",free:true, online:false,src:"Vassalli di Barbero", past:false,nuovo:true },
  {title:"Tour Sudafrica — Istituto Italiano Cultura",day:"—", month:"Apr",year:"2026",city:"Johannesburg/Pretoria",venue:"IIC",                       desc:"Conferenze organizzate dall'Istituto Italiano di Cultura",     price:"gratuito",free:true, online:false,src:"IIC",                past:false,nuovo:false},
  {title:"Lezioni di Storia — Tour Primavera 2026",   day:"—", month:"Apr",year:"2026",city:"Varie città",       venue:"Varie sedi",                    desc:"Tappe primaverili del tour Lezioni di Storia",                 price:"da €12",  free:false,online:false,src:"Laterza",            past:false,nuovo:false},
  {title:"Conferenza-spettacolo Estate 2026",         day:"—", month:"Giu",year:"2026",city:"TBA",               venue:"TBA",                           desc:"Conferenza annunciata per l'estate 2026",                      price:"n/d",     free:false,online:false,src:"Vassalli di Barbero", past:false,nuovo:false},
  {title:"Festival del Classico — Torino",            day:"—", month:"Nov",year:"2025",city:"Torino",             venue:"Circolo dei Lettori",           desc:"8ª edizione con Barbero ospite",                               price:"da €10",  free:false,online:false,src:"Circolo Lettori",    past:true, nuovo:false},
  {title:"BookCity Milano 2025",                      day:"—", month:"Nov",year:"2025",city:"Milano",             venue:"BookCity",                      desc:"Appuntamento annuale di Barbero a BookCity",                   price:"gratuito",free:true, online:false,src:"BookCity",            past:true, nuovo:false},
  {title:"Più Libri Più Liberi 2025",                 day:"—", month:"Dic",year:"2025",city:"Roma",               venue:"La Nuvola",                     desc:"Presenza annuale alla fiera romana del libro",                 price:"gratuito",free:true, online:false,src:"PLPL",               past:true, nuovo:false},
];

let allEvts = [];
let activeFilter = 'all';
let notifEnabled = false;
let autoTimer = null;

// ── API KEY (localStorage sicuro — solo GitHub Pages) ─
function getKey() {
  try { return localStorage.getItem('bbtrk_key') || ''; } catch(e){ return ''; }
}
function saveKey() {
  const v = document.getElementById('keyInput').value.trim();
  if (!v.startsWith('sk-ant-') && v !== '') { toast('⚠ Chiave non valida (deve iniziare con sk-ant-)'); return; }
  try { localStorage.setItem('bbtrk_key', v); } catch(e){}
  document.getElementById('keyBanner').classList.remove('show');
  toast('✔ Chiave salvata — puoi cercare!');
}

// ── INIT ─────────────────────────────────────────────
(function init() {
  renderSources();

  // Mostra banner key se non c'è chiave salvata
  if (!getKey()) document.getElementById('keyBanner').classList.add('show');

  const inp = document.getElementById('searchInput');
  ['input','keyup','keydown','change','compositionend'].forEach(ev => {
    inp.addEventListener(ev, () => {
      document.getElementById('clearBtn').classList.toggle('visible', inp.value.length > 0);
      filterRender();
    });
  });
})();

function clearSearch() {
  const inp = document.getElementById('searchInput');
  inp.value = '';
  document.getElementById('clearBtn').classList.remove('visible');
  inp.focus();
  filterRender();
}

// ── FONTI ─────────────────────────────────────────────
function renderSources() {
  document.getElementById('srcGrid').innerHTML = SOURCES.map((s,i) => `
    <button class="src ${s.on?'on':''}" id="src${i}" onclick="toggleSrc(${i})">
      <div class="src-dot"></div>
      <div class="src-name">${s.name}</div>
    </button>
  `).join('');
}
function toggleSrc(i) {
  SOURCES[i].on = !SOURCES[i].on;
  document.getElementById('src'+i).classList.toggle('on', SOURCES[i].on);
  toast(SOURCES[i].on ? '✔ '+SOURCES[i].name : '✘ '+SOURCES[i].name+' disattivato');
}

// ── NOTIFICHE ─────────────────────────────────────────
function handleNotif() {
  const checked = document.getElementById('notifCheck').checked;
  if (!checked) { disableNotif(); return; }
  document.getElementById('notifCheck').checked = false;

  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
  const isStandalone = window.navigator.standalone === true ||
                       window.matchMedia('(display-mode: standalone)').matches;

  if (isIOS && !isStandalone) { document.getElementById('iosAlert').classList.add('show'); return; }
  if (!('Notification' in window)) { toast('⚠ Browser non supporta notifiche'); return; }
  if (Notification.permission === 'denied') { toast('⚠ Notifiche bloccate — abilitale nelle impostazioni del browser'); return; }

  const isAndroid = /Android/.test(navigator.userAgent);
  if (isAndroid) { document.getElementById('androidAlert').classList.add('show'); return; }

  doRequestNotif();
}

async function doRequestNotif() {
  closeAndroidAlert();
  if (!('Notification' in window)) return;
  try {
    const p = await Notification.requestPermission();
    if (p === 'granted') enableNotif();
    else toast('⚠ Permesso negato');
  } catch(e) {
    Notification.requestPermission(p => { if (p === 'granted') enableNotif(); });
  }
}

function enableNotif() {
  notifEnabled = true;
  document.getElementById('notifCheck').checked = true;
  autoTimer = setInterval(() => fetchEvents(true), 30*60*1000);
  try { new Notification('✦ Barbero Tracker', {body:'Riceverai avvisi per nuovi spettacoli', icon:'data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 64 64%22%3E%3Ctext y=%2250%22 font-size=%2256%22%3E📖%3C/text%3E%3C/svg%3E'}); } catch(e){}
  toast('🔔 Notifiche attive — aggiorno ogni 30 min');
}

function disableNotif() {
  notifEnabled = false;
  document.getElementById('notifCheck').checked = false;
  clearInterval(autoTimer);
  toast('🔕 Notifiche disattivate');
}

function closeIosAlert() {
  document.getElementById('iosAlert').classList.remove('show');
  notifEnabled = true;
  document.getElementById('notifCheck').checked = true;
  autoTimer = setInterval(() => fetchEvents(true), 30*60*1000);
  toast('⏱ Aggiornamento automatico ogni 30 min attivo');
}
function closeAndroidAlert() { document.getElementById('androidAlert').classList.remove('show'); }

// ── FETCH ─────────────────────────────────────────────
async function fetchEvents(silent=false) {
  const apiKey = getKey();
  if (!apiKey) {
    document.getElementById('keyBanner').classList.add('show');
    toast('⚠ Inserisci prima la tua API key');
    return;
  }

  const btn = document.getElementById('fetchBtn');
  btn.disabled = true; btn.textContent = '⏳';
  document.getElementById('dot').className = 'dot orange';
  document.getElementById('statusTxt').textContent = 'RICERCA…';

  if (!silent) {
    document.getElementById('spinner').classList.add('show');
    document.getElementById('evtList').innerHTML = '';
    document.getElementById('aiBox').classList.remove('show');
    document.getElementById('filters').style.display = 'none';
  }

  const srcs = SOURCES.filter(s=>s.on).map(s=>s.name).join(', ');
  const oggi = new Date().toLocaleDateString('it-IT');

  try {
    const res = await fetch("https://api.anthropic.com/v1/messages", {
      method:"POST",
      headers:{
        "Content-Type":"application/json",
        "x-api-key": apiKey,
        "anthropic-version": "2023-06-01",
        "anthropic-dangerous-direct-browser-access": "true"
      },
      body: JSON.stringify({
        model:"claude-sonnet-4-20250514",
        max_tokens:1000,
        system:`Sei un assistente per trovare eventi del Professor Alessandro Barbero (storico italiano famoso per conferenze-spettacolo).
Data: ${oggi}. Rispondi SOLO con JSON valido puro, nessun testo extra, nessun backtick.
Schema esatto:
{"summary":"frase breve","events":[{"title":"","day":"","month":"","year":"","city":"","venue":"","desc":"","price":"","free":false,"online":false,"src":"","past":false,"nuovo":false}]}`,
        messages:[{role:"user",content:`Cerca spettacoli, conferenze ed eventi di Alessandro Barbero 2025-2026. Fonti: ${srcs}. Dai 8-12 eventi con date, città e teatri precisi.`}],
        tools:[{type:"web_search_20250305",name:"web_search"}]
      })
    });

    if (!res.ok) {
      const err = await res.json().catch(()=>({}));
      throw new Error(err?.error?.message || `HTTP ${res.status}`);
    }

    const data = await res.json();
    const txt = (data.content||[]).map(x=>x.type==='text'?x.text:'').join('');
    const j0 = txt.indexOf('{'), j1 = txt.lastIndexOf('}');
    if (j0<0||j1<0) throw new Error('no json');
    const parsed = JSON.parse(txt.slice(j0,j1+1));

    const prev = allEvts.length;
    allEvts = parsed.events || [];

    if (parsed.summary) {
      document.getElementById('aiBox').textContent = parsed.summary;
      document.getElementById('aiBox').classList.add('show');
    }

    document.getElementById('lastUpd').textContent = 'Ore '+new Date().toLocaleTimeString('it-IT',{hour:'2-digit',minute:'2-digit'});
    document.getElementById('dot').className = 'dot';
    document.getElementById('statusTxt').textContent = 'AGGIORNATO';
    document.getElementById('filters').style.display = 'flex';
    filterRender();

    if (!silent) toast(`✦ ${allEvts.length} eventi trovati`);
    if (silent && notifEnabled && allEvts.length > prev) {
      try { new Notification('🎭 Nuovo spettacolo di Barbero!', {body: allEvts[0].title}); } catch(e){}
    }

  } catch(err) {
    document.getElementById('dot').className = 'dot red';
    document.getElementById('statusTxt').textContent = 'ERRORE';
    if (!silent) {
      allEvts = FALLBACK;
      const b = document.getElementById('aiBox');
      b.textContent = (err.message.includes('401') || err.message.includes('auth'))
        ? '⚠ API key non valida o scaduta — aggiorna la chiave e riprova.'
        : 'Errore di rete — mostro eventi noti. Per dati aggiornati riprova tra poco.';
      b.classList.add('show');
      document.getElementById('filters').style.display = 'flex';
      filterRender();
      toast('📋 '+err.message);
    }
  } finally {
    btn.disabled = false;
    btn.textContent = '✦ Cerca';
    document.getElementById('spinner').classList.remove('show');
  }
}

// ── FILTRI ────────────────────────────────────────────
function setChip(f) {
  activeFilter = f;
  ['cAll','cFuture','cFree'].forEach(id=>document.getElementById(id).classList.remove('on'));
  ({all:'cAll',future:'cFuture',free:'cFree'})[f] && document.getElementById({all:'cAll',future:'cFuture',free:'cFree'}[f]).classList.add('on');
  filterRender();
}

function filterRender() {
  let evts = [...allEvts];
  if (activeFilter==='future') evts=evts.filter(e=>!e.past);
  if (activeFilter==='free')   evts=evts.filter(e=>e.free);
  const q = (document.getElementById('searchInput').value||'').toLowerCase().trim();
  if (q) evts=evts.filter(e=>
    (e.title||'').toLowerCase().includes(q)||
    (e.city||'').toLowerCase().includes(q)||
    (e.venue||'').toLowerCase().includes(q)||
    (e.desc||'').toLowerCase().includes(q)
  );
  renderEvts(evts);
}

function renderEvts(evts) {
  const list = document.getElementById('evtList');
  const cnt  = document.getElementById('evtCount');
  if (!evts.length) {
    list.innerHTML = `<div class="empty"><span class="empty-ico">🔍</span><p>Nessun evento trovato</p></div>`;
    cnt.textContent = ''; return;
  }
  cnt.textContent = `${evts.length} eventi · ${evts.filter(e=>!e.past).length} futuri`;
  list.innerHTML = evts.map((e,i)=>`
    <div class="card ${e.past?'past':''} ${e.nuovo?'nuovo':''}" style="animation-delay:${Math.min(i*0.04,0.5)}s">
      <div class="card-top">
        <div class="date-block">
          <div class="date-day">${e.day||'—'}</div>
          <div class="date-mon">${e.month||''}</div>
          <div class="date-yr">${e.year||''}</div>
        </div>
        <div class="card-body">
          <div class="card-title">${e.title}</div>
          <div class="card-meta">
            ${e.city  ?`<span>📍 ${e.city}</span>`:''}
            ${e.venue ?`<span>🎭 ${e.venue}</span>`:''}
            ${e.price ?`<span>🎟 ${e.price}</span>`:''}
          </div>
          ${e.desc?`<div class="card-desc">${e.desc}</div>`:''}
          <div class="card-tags">
            ${e.nuovo ?'<span class="tag tag-new">Nuovo</span>':''}
            ${e.free  ?'<span class="tag tag-free">Gratuito</span>':'<span class="tag tag-paid">A pagamento</span>'}
            ${e.online?'<span class="tag tag-web">Online</span>':''}
            ${e.past  ?'<span class="tag tag-past">Passato</span>':''}
          </div>
        </div>
        <div class="src-badge">${e.src||''}</div>
      </div>
    </div>
  `).join('');
}

// ── TOAST ─────────────────────────────────────────────
let _tt;
function toast(msg) {
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  clearTimeout(_tt);
  _tt=setTimeout(()=>t.classList.remove('show'),3200);
}
</script>
</body>
</html>
